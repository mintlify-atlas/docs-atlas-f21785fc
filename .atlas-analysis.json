{
  "projectType": "ai-ml",
  "projectName": "Meganeura",
  "projectDescription": "A cross-platform Rust library for GPU-accelerated neural network training and inference, using e-graph (egglog) optimization and blade-graphics for portable GPU access across Vulkan and Metal.",
